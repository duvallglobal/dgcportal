# ============================================
# DGC Client Portal - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# --- Clerk Auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/intake

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- DocuSeal ---
DOCUSEAL_API_URL=https://api.docuseal.co
DOCUSEAL_API_KEY=your_docuseal_api_key

# --- NVIDIA NIM AI ---
NVIDIA_API_KEY=nvapi-...

# --- Resend Email ---
RESEND_API_KEY=re_...
ADMIN_EMAIL=admin@dfrmdgc.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Vercel Cron ---
CRON_SECRET=your_cron_secret_here

# --- Encryption ---
# 32-byte key for AES-256-GCM encryption of platform credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=2a61bf07232accd497d7d39f371c5e03e60c393326fc9ab1cceaa55a2758c648
